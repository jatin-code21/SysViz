---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';

interface Props {
  entry: CollectionEntry<'concepts'>;
  headings: MarkdownHeading[];
}

const { entry, headings } = Astro.props;
const { title, description, category, tags, updated, links } = entry.data;

const toc = headings.filter((h) => h.depth === 2);
const base = import.meta.env.BASE_URL;

// Accent the last word of the title, mirroring the reference style
const words = title.split(' ');
const titleHead = words.slice(0, -1).join(' ');
const titleTail = words[words.length - 1];

const updatedLabel = updated.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});
---

<BaseLayout title={`${title} — SysViz`} description={description}>
  <div class="flex min-h-screen">
    <nav class="hidden md:block w-[260px] shrink-0 bg-nav border-r border-line text-nav-ink px-4 py-6 sticky top-0 h-screen overflow-y-auto">
      <a href={base} class="block font-bold text-white text-[1.05rem] tracking-[.5px]">
        Sys<span class="text-accent">Viz</span>
      </a>
      <div class="text-xs text-nav-muted mb-5 mt-0.5">{category} · Cheat Sheet</div>
      <a
        href={base}
        class="block text-[.85rem] text-nav-muted hover:text-white rounded-md px-2 py-1.5 mb-3 hover:bg-nav-hover"
      >
        ← All concepts
      </a>
      {toc.map((h, i) => (
        <a
          href={`#${h.slug}`}
          class="block text-[.85rem] leading-[1.3] rounded-md px-2 py-1.5 mb-0.5 hover:bg-nav-hover hover:text-white"
        >
          {i + 1}. {h.text}
        </a>
      ))}
    </nav>

    <main class="flex-1 min-w-0 max-w-[980px] px-5 py-6 md:px-12 md:py-10 pb-20">
      <a href={base} class="md:hidden block text-nav-muted text-sm mb-4">← SysViz · All concepts</a>

      <header class="mb-8">
        <h1 class="text-white text-[2.1rem] font-bold tracking-tight leading-tight mb-1.5">
          {titleHead && `${titleHead} `}<span class="text-accent">{titleTail}</span>
        </h1>
        <p class="text-hero-ink mb-4">{description}</p>
        <div class="flex flex-wrap items-center gap-2">
          {tags.map((tag) => (
            <span class="text-xs text-accent-ink bg-accent-soft border border-accent-line rounded-full px-2.5 py-1">{tag}</span>
          ))}
          <span class="text-xs text-nav-muted ml-1">Updated {updatedLabel}</span>
        </div>
      </header>

      <article class="concept-prose">
        <slot />
      </article>

      {links.length > 0 && (
        <footer class="text-nav-muted text-sm text-center pt-5">
          Useful links:{' '}
          {links.map((link, i) => (
            <>
              {i > 0 && ' · '}
              <a href={link.href} target="_blank" rel="noreferrer" class="text-accent hover:underline">
                {link.label}
              </a>
            </>
          ))}
        </footer>
      )}
    </main>
  </div>
</BaseLayout>
