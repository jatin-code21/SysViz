---
interface Props {
  type?: 'info' | 'tip' | 'warn';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const variants = {
  info: {
    icon: 'ℹ️',
    box: 'bg-[rgba(56,189,248,.08)] border-[rgba(56,189,248,.3)]',
    heading: 'text-[#7dd3fc]',
  },
  tip: {
    icon: '💡',
    box: 'bg-[rgba(52,211,153,.08)] border-[rgba(52,211,153,.3)]',
    heading: 'text-[#6ee7b7]',
  },
  warn: {
    icon: '⚠️',
    box: 'bg-[rgba(251,191,36,.08)] border-[rgba(251,191,36,.3)]',
    heading: 'text-[#fcd34d]',
  },
};
const v = variants[type];
---

<div class={`callout border rounded-lg px-4 py-3 my-3 text-[.9rem] leading-normal ${v.box}`}>
  {title && <div class={`font-bold mb-1 ${v.heading}`}>{v.icon} {title}</div>}
  <slot />
</div>

<style>
  /* Callout content is compact: kill the default list/paragraph chrome */
  .callout :global(p) {
    margin: 0;
  }
  .callout :global(ul > li) {
    border-bottom: none;
    padding: 2px 0;
  }
</style>
