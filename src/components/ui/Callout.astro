---
interface Props {
  type?: 'info' | 'tip' | 'warn';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const variants = {
  info: {
    icon: 'ℹ️',
    box: 'bg-info-bg border-info-line',
    heading: 'text-info-ink',
  },
  tip: {
    icon: '💡',
    box: 'bg-tip-bg border-tip-line',
    heading: 'text-tip-ink',
  },
  warn: {
    icon: '⚠️',
    box: 'bg-warn-bg border-warn-line',
    heading: 'text-warn-ink',
  },
};
const v = variants[type];
---

<div class={`callout border rounded-lg px-4 py-3 my-3 text-[.9rem] leading-normal ${v.box}`}>
  {title && <div class={`font-bold mb-1 ${v.heading}`}>{v.icon} {title}</div>}
  <slot />
</div>

<style>
  /* Callout content is compact: kill the default list/paragraph chrome */
  .callout :global(p) {
    margin: 0;
  }
  .callout :global(ul > li) {
    border-bottom: none;
    padding: 2px 0;
  }
</style>
