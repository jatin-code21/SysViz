---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ConceptExplorer, { type ConceptMeta } from '../components/ConceptExplorer.tsx';

const entries = await getCollection('concepts');

const concepts: ConceptMeta[] = await Promise.all(
  entries.map(async (entry) => {
    const { headings } = await render(entry);
    return {
      slug: entry.id,
      title: entry.data.title,
      description: entry.data.description,
      category: entry.data.category,
      tags: entry.data.tags,
      updated: entry.data.updated.toLocaleDateString('en-GB', {
        day: 'numeric',
        month: 'short',
        year: 'numeric',
      }),
      sections: headings.filter((h) => h.depth === 2).map((h) => h.text),
    };
  }),
);

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="SysViz — Concept Cheatsheets">
  <main class="max-w-[1080px] mx-auto px-5 py-10 md:py-16">
    <header class="mb-8 flex items-start justify-between gap-4">
      <div>
        <div class="text-heading font-bold text-2xl tracking-[.5px]">
          Sys<span class="text-accent">Viz</span>
        </div>
        <p class="text-hero-ink mt-1.5 max-w-xl">
          Personal cheatsheets for backend concepts — structured, visual, and quick to recall.
          One page per concept; it grows as I learn.
        </p>
      </div>
      <button
        type="button"
        data-theme-toggle
        title="Toggle light / dark theme"
        class="w-8 h-8 shrink-0 rounded-lg border border-line bg-panel text-sub hover:text-accent-ink hover:border-accent-line transition-colors cursor-pointer text-sm"
      ></button>
    </header>

    <ConceptExplorer client:load concepts={concepts} base={base} />
  </main>
</BaseLayout>
